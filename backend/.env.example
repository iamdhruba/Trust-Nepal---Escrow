NODE_ENV=production
PORT=3000

# Database
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/trustnepal?retryWrites=true&w=majority

# Payment Gateways (Production Keys)
ESEWA_SECRET=your_esewa_production_secret
ESEWA_PRODUCT_CODE=your_esewa_product_code
KHALTI_SECRET=your_khalti_production_secret

# Security
AUDIT_SECRET=your_secure_audit_secret_64_chars
JWT_SECRET=your_secure_jwt_secret_base64

# Mobile Deep Link / Web Redirect
APP_DEEP_LINK=https://app.trustnepal.com

# AWS S3 (for KYC uploads)
AWS_REGION=ap-south-1
S3_BUCKET=trustnepal-uploads-prod
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# External SMS API
SMS_API_KEY=your_sparrow_sms_production_key

# Firebase Admin SDK (for Phone Auth)
FIREBASE_PROJECT_ID=trustnepal-ab17e
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@trustnepal-ab17e.iam.gserviceaccount.com
FIREBASE_STORAGE_BUCKET=trustnepal-ab17e.appspot.com
