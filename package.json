{
  "name": "nepaltrust-monorepo",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "backend",
    "admin-web",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "test": "npm test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5"
  }
}
